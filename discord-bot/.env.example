# ── Bot Token ──────────────────────────────────────────
# Discord Developer Portal > Bot > Token
DISCORD_BOT_TOKEN=DISCORD_BOT_TOKEN_GOES_HERE

# ── API Server ─────────────────────────────────────────
# Must match BOT_API_URL and BOT_API_SECRET in backend/.env
BOT_API_PORT=4001
BOT_API_SECRET=BOT_API_SECRET_GOES_HERE

# ── Discord Server ─────────────────────────────────────
# Right-click your server > Copy Server ID (Developer Mode must be on)
GUILD_ID=GUILD_ID_GOES_HERE
